# ARIA Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# === LLM (Ollama — local, free) ===
# Install Ollama from https://ollama.com and pull a model:
#   ollama pull gemma3:1b       (lightweight, works on most laptops)
#   ollama pull gemma3:12b      (better quality, needs 8GB+ RAM)
OLLAMA_MODEL=gemma3:1b
OLLAMA_MODEL_FAST=gemma3:1b
OLLAMA_BASE_URL=http://localhost:11434

# === NCBI API Key (optional — for PubMed searches) ===
# Get free key at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=26300f1cf88c8c03e761c18ddefb9a7d5409

# === Gemini API Key (optional — legacy, not used by default) ===
# Get free key at: https://ai.google.dev
GEMINI_API_KEY=
